<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="30dp"
    xmlns:tools="http://schemas.android.com/tools">




    <TextView
        android:id="@+id/CategorieDepense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_toEndOf="@+id/imgdepense"
        android:textColor="@color/black"
        android:textSize="25sp"
        tools:text="Categorie_Name"/>


    <TextView
        android:id="@+id/montantDepense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="200sp"
        android:layout_below="@id/CategorieDepense"
        android:layout_toEndOf="@+id/imgdepense"
        android:textColor="@color/black"
        android:textSize="20dp"
        tools:text="0.0" />




    <TextView
        android:id="@+id/MoyenPaiementDepense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_below="@id/montantDepense"
        android:layout_toEndOf="@+id/imgdepense"
        android:textColor="@color/black"
        android:textSize="20dp"
        tools:text="Moyen de paiment" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_below="@id/imgdepense"
        android:layout_marginTop="50dp"
        android:background="@color/orange"/>

</RelativeLayout>

